# Glass Aero Production Tracker - Environment Configuration
# Copy this file to .env and update ALL values

# ===========================================
# REQUIRED - Generate unique values for each deployment
# ===========================================

# Database password (generate with: openssl rand -base64 32)
POSTGRES_PASSWORD=CHANGE_ME

# Server URL (replace with actual server IP or hostname)
SITE_URL=http://YOUR_SERVER_IP:8080

# ===========================================
# JWT Configuration
# Generate a new secret with: openssl rand -base64 40
# Then generate ANON_KEY and SERVICE_KEY using that secret
# See: https://supabase.com/docs/guides/self-hosting/docker
# ===========================================

JWT_SECRET=CHANGE_ME
ANON_KEY=CHANGE_ME
SERVICE_KEY=CHANGE_ME

# ===========================================
# Realtime Configuration
# Generate with: openssl rand -base64 64
# ===========================================

SECRET_KEY_BASE=CHANGE_ME
